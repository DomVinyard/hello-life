#!/usr/bin/env node
// Life 0.1 kernel — single-file distribution
// Built: 2026-05-28T21:07:08.787Z

(function() {
const _modules = {};
function _define(name, factory) { let m; _modules[name] = () => m || (m = factory()); }
function _require(name) { if (_modules[name]) return _modules[name](); return require(name); }

_define("parser", function() {
const fs = require('fs');
const path = require('path');

function parseLifeFile(filePath) {
  const raw = fs.readFileSync(filePath, 'utf-8');
  const match = raw.match(/^([\s\S]*?)---\s*\n([\s\S]*)$/);
  const frontmatter = match ? match[1] : raw;
  const body = match ? match[2].trim() : '';
  const parsed = parseYaml(frontmatter.trim());
  return { ...parsed, _body: body, _path: filePath };
}

function parseYaml(text) {
  const result = {};
  let currentKey = null;
  let currentSubKey = null;

  for (const line of text.split('\n')) {
    if (line.trim() === '' || line.trim().startsWith('#')) continue;
    const indent = line.match(/^(\s*)/)[1].length;

    if (indent === 0) {
      const m = line.match(/^(\w[\w_-]*):\s*(.*)/);
      if (m) {
        currentKey = m[1];
        currentSubKey = null;
        const val = m[2].trim();
        if (val === '') {
          result[currentKey] = undefined;
        } else if (val.startsWith('[') && val.endsWith(']')) {
          const inner = val.slice(1, -1).trim();
          result[currentKey] = inner ? inner.split(',').map(s => s.trim()).filter(Boolean) : [];
        } else {
          result[currentKey] = val;
        }
      }
      continue;
    }

    const listMatch = line.match(/^\s+-\s+(.*)/);
    if (listMatch && currentKey) {
      if (!Array.isArray(result[currentKey])) result[currentKey] = [];
      result[currentKey].push(listMatch[1].trim());
      continue;
    }

    if (indent === 2 && currentKey) {
      const m = line.match(/^\s{2}(\w[\w_-]*):\s*(.*)/);
      if (m) {
        if (typeof result[currentKey] !== 'object' || Array.isArray(result[currentKey]))
          result[currentKey] = {};
        currentSubKey = m[1];
        result[currentKey][currentSubKey] = m[2].trim() || {};
      }
      continue;
    }

    if (indent >= 4 && currentKey && currentSubKey) {
      const m = line.trim().match(/^(\w[\w_-]*):\s*(.*)/);
      if (m && typeof result[currentKey][currentSubKey] === 'object') {
        let val = m[2].trim();
        if (val.startsWith('[') && val.endsWith(']'))
          val = val.slice(1, -1).split(',').map(s => s.trim()).filter(Boolean);
        result[currentKey][currentSubKey][m[1]] = val;
      }
      continue;
    }
  }
  return result;
}

function findRoot(dir) {
  let d = path.resolve(dir);
  while (d !== path.dirname(d)) {
    if (fs.existsSync(path.join(d, '.life.core'))) return d;
    d = path.dirname(d);
  }
  return null;
}

function discoverLifeFiles(root) {
  const files = [];
  // Root .life file
  const rootLife = path.join(root, '.life');
  if (fs.existsSync(rootLife) && fs.statSync(rootLife).isFile()) files.push(rootLife);

  function walk(dir, depth) {
    if (depth > 5) return;
    const base = path.basename(dir);
    if (['node_modules', '.git', 'dist'].includes(base)) return;

    if (dir !== root) {
      const lf = path.join(dir, '.life');
      if (fs.existsSync(lf) && fs.statSync(lf).isFile()) files.push(lf);
    }

    try {
      for (const entry of fs.readdirSync(dir)) {
        if (entry.startsWith('.') && entry !== '.life') continue;
        const full = path.join(dir, entry);
        if (fs.statSync(full).isDirectory()) walk(full, depth + 1);
      }
    } catch {}
  }
  walk(root, 0);
  return files;
}

function buildIndex(root) {
  return discoverLifeFiles(root).map(f => {
    try {
      const parsed = parseLifeFile(f);
      const relPath = path.relative(root, path.dirname(f));
      return {
        path: relPath || '.',
        file: path.relative(root, f),
        name: parsed.name || path.basename(relPath || '.'),
        summary: parsed.summary || '',
        requires: parsed.requires || [],
        provides: parsed.provides || [],
        commands: parsed.commands ? Object.keys(parsed.commands) : [],
        checks: parsed.checks || [],
        secrets: parsed.secrets || [],
        skills: parsed.skills || [],
        hooks: parsed.hooks || {},
        _parsed: parsed,
      };
    } catch (e) {
      console.error(`Warning: ${f}: ${e.message}`);
      return null;
    }
  }).filter(Boolean);
}

return { parseLifeFile, findRoot, discoverLifeFiles, buildIndex };

});

_define("graph", function() {
function resolveGraph(index) {
  const provided = new Map();
  const missing = [];
  const warnings = [];

  for (const entry of index) {
    for (const cap of entry.provides || []) {
      if (provided.has(cap))
        warnings.push(`Ambiguous: ${cap} from ${provided.get(cap).name} and ${entry.name}`);
      provided.set(cap, entry);
    }
  }

  for (const entry of index) {
    for (const rawCap of entry.requires || []) {
      const cap = rawCap.replace(/:\s*public$/, '');
      if (!provided.has(cap))
        missing.push({ dir: entry.name, capability: cap, raw: rawCap });
    }
  }

  return { provided, missing, warnings };
}

function dependentsOf(name, index) {
  return index.filter(e =>
    (e.requires || []).some(r => r.replace(/:\s*public$/, '').startsWith(name + '.'))
  );
}

return { resolveGraph, dependentsOf };

});

_define("skills", function() {
// Skill resolver — fetches skill content from GitHub URL@commit or local path.
// Caches at ~/.life/cache/skills/<sha>/SKILL.md
//
// Source formats:
//   github.com/user/repo/path/to/skill@commit   → fetch raw SKILL.md from that path
//   ./local/path/to/skill                       → read locally

const fs = require('fs');
const path = require('path');
const os = require('os');
const crypto = require('crypto');

const CACHE_DIR = path.join(os.homedir(), '.life', 'cache', 'skills');

function cacheKey(source) {
  return crypto.createHash('sha256').update(source).digest('hex').slice(0, 16);
}

function parseFrontmatter(text) {
  const m = text.match(/^---\s*\n([\s\S]*?)\n---\s*\n([\s\S]*)$/);
  if (!m) return { fm: {}, body: text };
  const fm = {};
  for (const line of m[1].split('\n')) {
    const km = line.match(/^(\w[\w_-]*):\s*(.*)$/);
    if (km) fm[km[1]] = km[2].trim();
  }
  return { fm, body: m[2] };
}

async function fetchRemote(source) {
  const m = source.match(/^github\.com\/([^/]+)\/([^/]+)\/(.+?)@(.+)$/);
  if (!m) throw new Error(`Invalid GitHub skill source: ${source}`);
  const [, user, repo, subpath, commit] = m;
  const url = `https://raw.githubusercontent.com/${user}/${repo}/${commit}/${subpath}/SKILL.md`;
  const res = await fetch(url);
  if (!res.ok) throw new Error(`Failed to fetch ${url}: HTTP ${res.status}`);
  return await res.text();
}

function isImmutableRef(source) {
  // Cache only when the @<ref> looks like a SHA (hex, ≥7 chars). Tagged refs
  // like @main, @master, @v1 can move so we always refetch them.
  const m = source.match(/@([^@]+)$/);
  if (!m) return false;
  const ref = m[1];
  return /^[0-9a-f]{7,40}$/i.test(ref);
}

async function resolveSkill(source, repoRoot) {
  const isLocal = source.startsWith('./') || source.startsWith('/');

  let content;
  let cached = false;
  if (isLocal) {
    const abs = path.isAbsolute(source) ? source : path.resolve(repoRoot, source);
    const skillFile = path.join(abs, 'SKILL.md');
    if (!fs.existsSync(skillFile)) throw new Error(`No SKILL.md at ${abs}`);
    content = fs.readFileSync(skillFile, 'utf-8');
  } else {
    const key = cacheKey(source);
    const cachePath = path.join(CACHE_DIR, key, 'SKILL.md');
    const useCache = isImmutableRef(source) && fs.existsSync(cachePath);
    if (useCache) {
      content = fs.readFileSync(cachePath, 'utf-8');
      cached = true;
    } else {
      content = await fetchRemote(source);
      fs.mkdirSync(path.dirname(cachePath), { recursive: true });
      fs.writeFileSync(cachePath, content);
    }
  }

  const { fm } = parseFrontmatter(content);
  let name = fm.name;
  if (!name) {
    if (isLocal) {
      name = path.basename(path.resolve(repoRoot, source));
    } else {
      const m = source.match(/^github\.com\/[^/]+\/[^/]+\/(.+?)@/);
      name = m ? path.basename(m[1]) : 'unnamed';
    }
  }

  return { name, content, source, cached };
}

async function resolveAllSkills(sources, repoRoot) {
  const resolved = [];
  for (const source of sources) {
    try {
      resolved.push(await resolveSkill(source, repoRoot));
    } catch (e) {
      resolved.push({ source, error: e.message });
    }
  }
  return resolved;
}

return { resolveSkill, resolveAllSkills, CACHE_DIR };

});

_define("cloudflare", function() {
const fs = require('fs');
const path = require('path');

const ID = 'cloudflare';

function detect() {
  return !!(process.env.CLOUDFLARE_API_TOKEN && process.env.CLOUDFLARE_ACCOUNT_ID);
}

function headers() {
  return { 'Authorization': `Bearer ${process.env.CLOUDFLARE_API_TOKEN}` };
}

function accountUrl(p) {
  return `https://api.cloudflare.com/client/v4/accounts/${process.env.CLOUDFLARE_ACCOUNT_ID}${p || ''}`;
}

async function cfFetch(path, opts = {}) {
  const res = await fetch(accountUrl(path), { headers: headers(), ...opts });
  let data;
  try { data = await res.json(); } catch { return { _status: res.status, _ok: false }; }
  return { _status: res.status, _ok: data.success, ...data };
}

// ============================================================
// Resource handlers
// One entry per infra.* capability. Each maps the semantic
// capability to provider-specific resource lifecycle.
//
// Each handler defines:
//   resourceName(entry) — vendor-side name derived from the entry
//   bindingVar         — the env.<VAR> name the worker sees
//   provision(entry)   — create-or-return-existing → { ok, id }
//   verify(entry)      — true if resource exists for this entry
//   binding(entry)     — metadata.bindings[] entry for worker upload
//   teardown(entry)    — delete the resource
// ============================================================

const RESOURCES = {
  'infra.kv': {
    resourceName: (entry) => `${entry.name}-kv`,
    bindingVar: 'KV',
    async provision(entry) {
      const title = this.resourceName(entry);
      const list = await cfFetch('/storage/kv/namespaces?per_page=100');
      if (list._ok) {
        const existing = (list.result || []).find(n => n.title === title);
        if (existing) return { ok: true, id: existing.id, existed: true };
      }
      const create = await cfFetch('/storage/kv/namespaces', {
        method: 'POST',
        headers: { ...headers(), 'Content-Type': 'application/json' },
        body: JSON.stringify({ title }),
      });
      if (!create._ok) return { ok: false, error: JSON.stringify(create.errors) };
      return { ok: true, id: create.result.id, existed: false };
    },
    async verify(entry) {
      const title = this.resourceName(entry);
      const list = await cfFetch('/storage/kv/namespaces?per_page=100');
      if (!list._ok) return false;
      return (list.result || []).some(n => n.title === title);
    },
    async binding(entry) {
      const p = await this.provision(entry);
      if (!p.ok) return null;
      return { type: 'kv_namespace', name: this.bindingVar, namespace_id: p.id };
    },
    async teardown(entry) {
      const title = this.resourceName(entry);
      const list = await cfFetch('/storage/kv/namespaces?per_page=100');
      if (!list._ok) return { ok: false, error: 'Could not list KV namespaces' };
      const existing = (list.result || []).find(n => n.title === title);
      if (!existing) return { ok: true, message: 'KV not present' };
      const del = await cfFetch(`/storage/kv/namespaces/${existing.id}`, { method: 'DELETE' });
      return { ok: del._ok, message: del._ok ? `KV "${title}" deleted` : JSON.stringify(del.errors) };
    },
  },

  'infra.datastore': {
    resourceName: (entry) => `${entry.name}-db`,
    bindingVar: 'DB',
    async provision(entry) {
      const name = this.resourceName(entry);
      const list = await cfFetch('/d1/database?per_page=100');
      if (list._ok) {
        const existing = (list.result || []).find(d => d.name === name);
        if (existing) return { ok: true, id: existing.uuid, existed: true };
      }
      const create = await cfFetch('/d1/database', {
        method: 'POST',
        headers: { ...headers(), 'Content-Type': 'application/json' },
        body: JSON.stringify({ name }),
      });
      if (!create._ok) return { ok: false, error: JSON.stringify(create.errors) };
      return { ok: true, id: create.result.uuid, existed: false };
    },
    async verify(entry) {
      const name = this.resourceName(entry);
      const list = await cfFetch('/d1/database?per_page=100');
      if (!list._ok) return false;
      return (list.result || []).some(d => d.name === name);
    },
    async binding(entry) {
      const p = await this.provision(entry);
      if (!p.ok) return null;
      return { type: 'd1', name: this.bindingVar, id: p.id };
    },
    async teardown(entry) {
      const name = this.resourceName(entry);
      const list = await cfFetch('/d1/database?per_page=100');
      if (!list._ok) return { ok: false, error: 'Could not list D1 databases' };
      const existing = (list.result || []).find(d => d.name === name);
      if (!existing) return { ok: true, message: 'D1 not present' };
      const del = await cfFetch(`/d1/database/${existing.uuid}`, { method: 'DELETE' });
      return { ok: del._ok, message: del._ok ? `D1 "${name}" deleted` : JSON.stringify(del.errors) };
    },
  },

  'infra.object_store': {
    resourceName: (entry) => `${entry.name}-objects`,
    bindingVar: 'OBJECTS',
    async provision(entry) {
      const name = this.resourceName(entry);
      const list = await cfFetch('/r2/buckets');
      if (list._ok) {
        const existing = (list.result?.buckets || []).find(b => b.name === name);
        if (existing) return { ok: true, id: name, existed: true };
      }
      const create = await cfFetch('/r2/buckets', {
        method: 'POST',
        headers: { ...headers(), 'Content-Type': 'application/json' },
        body: JSON.stringify({ name }),
      });
      if (!create._ok) return { ok: false, error: JSON.stringify(create.errors) };
      return { ok: true, id: name, existed: false };
    },
    async verify(entry) {
      const name = this.resourceName(entry);
      const list = await cfFetch('/r2/buckets');
      if (!list._ok) return false;
      return (list.result?.buckets || []).some(b => b.name === name);
    },
    async binding(entry) {
      const p = await this.provision(entry);
      if (!p.ok) return null;
      return { type: 'r2_bucket', name: this.bindingVar, bucket_name: p.id };
    },
    async teardown(entry) {
      const name = this.resourceName(entry);
      // R2 requires the bucket be empty before delete. Drain it first.
      try {
        let cursor = null;
        for (let i = 0; i < 50; i++) {
          const q = cursor ? `?cursor=${encodeURIComponent(cursor)}` : '';
          const list = await cfFetch(`/r2/buckets/${name}/objects${q}`);
          if (!list._ok) break;
          const objects = list.result || [];
          if (!objects.length) break;
          for (const obj of objects) {
            await cfFetch(`/r2/buckets/${name}/objects/${encodeURIComponent(obj.key)}`, { method: 'DELETE' });
          }
          cursor = list.result_info?.cursor;
          if (!cursor) break;
        }
      } catch {}
      const del = await cfFetch(`/r2/buckets/${name}`, { method: 'DELETE' });
      if (del._status === 404) return { ok: true, message: 'R2 not present' };
      return { ok: del._ok, message: del._ok ? `R2 "${name}" deleted` : JSON.stringify(del.errors) };
    },
  },

  'infra.compute': null,
  'infra.route': null,
  'infra.secret_store': null,
};

function handlerFor(rawCap) {
  const cap = rawCap.replace(/:\s*public$/, '');
  return RESOURCES[cap] ?? undefined;
}

function resourcesNeeded(entry) {
  const out = [];
  for (const rawCap of entry.requires || []) {
    const h = handlerFor(rawCap);
    if (h) out.push({ cap: rawCap, handler: h });
  }
  return out;
}

// ============================================================
// Lifecycle
// ============================================================

async function connect() {
  const token = process.env.CLOUDFLARE_API_TOKEN;
  const accountId = process.env.CLOUDFLARE_ACCOUNT_ID;
  if (!token) return { ok: false, error: 'CLOUDFLARE_API_TOKEN not set' };
  if (!accountId) return { ok: false, error: 'CLOUDFLARE_ACCOUNT_ID not set' };
  const r = await cfFetch();
  if (!r._ok) return { ok: false, error: r.errors?.[0]?.message || 'Account not accessible' };
  return { ok: true, account: r.result.name };
}

async function provision(entry) {
  const needed = resourcesNeeded(entry);
  const provisioned = [];
  for (const { cap, handler } of needed) {
    const result = await handler.provision(entry);
    if (!result.ok) return { ok: false, error: `${cap}: ${result.error}` };
    provisioned.push({ cap, handler, ...result });
  }
  return { ok: true, provisioned };
}

async function deploy(dir, entry) {
  const workerPath = path.join(dir, 'src', 'worker.js');
  if (!fs.existsSync(workerPath))
    return { ok: false, error: `No src/worker.js in ${dir}` };

  const prov = await provision(entry);
  if (!prov.ok) return { ok: false, error: prov.error };

  const bindings = [];
  for (const p of prov.provisioned) {
    const b = await p.handler.binding(entry);
    if (b) bindings.push(b);
  }

  const code = fs.readFileSync(workerPath, 'utf-8');
  const name = entry.name;

  const formData = new FormData();
  formData.append('metadata', new Blob([JSON.stringify({
    main_module: 'worker.js',
    compatibility_date: '2024-01-01',
    bindings,
  })], { type: 'application/json' }));
  formData.append('worker.js', new Blob([code], { type: 'application/javascript+module' }), 'worker.js');

  const res = await fetch(accountUrl(`/workers/scripts/${name}`), {
    method: 'PUT',
    headers: headers(),
    body: formData,
  });
  const data = await res.json();
  if (!data.success) return { ok: false, error: JSON.stringify(data.errors) };

  let url = null;
  try {
    await cfFetch(`/workers/scripts/${name}/subdomain`, {
      method: 'POST',
      headers: { ...headers(), 'Content-Type': 'application/json' },
      body: JSON.stringify({ enabled: true }),
    });
    const sub = await cfFetch('/workers/subdomain');
    if (sub._ok && sub.result?.subdomain) {
      url = `https://${name}.${sub.result.subdomain}.workers.dev`;
    }
  } catch {}

  const bindingNames = bindings.map(b => b.name).join(', ');
  const bindingsMsg = bindings.length ? ` · bindings: ${bindingNames}` : '';
  return {
    ok: true,
    message: url ? `Worker "${name}" deployed → ${url}${bindingsMsg}` : `Worker "${name}" deployed${bindingsMsg}`,
    url,
  };
}

async function urlFor(entry) {
  const sub = await cfFetch('/workers/subdomain');
  if (sub._ok && sub.result?.subdomain) {
    return `https://${entry.name}.${sub.result.subdomain}.workers.dev`;
  }
  return null;
}

async function exists(entry) {
  const r = await cfFetch(`/workers/scripts/${entry.name}/settings`);
  return r._status !== 404;
}

async function listSecrets(entry) {
  const r = await cfFetch(`/workers/scripts/${entry.name}/secrets`);
  if (r._status === 404) return null;
  if (!r._ok) return null;
  return (r.result || []).map(s => s.name);
}

async function setSecret(entry, name, value) {
  const settings = await cfFetch(`/workers/scripts/${entry.name}/settings`);
  if (settings._status === 404) return { ok: false, error: `Deploy ${entry.name} first, then set secrets.` };
  const r = await cfFetch(`/workers/scripts/${entry.name}/secrets`, {
    method: 'PUT',
    headers: { ...headers(), 'Content-Type': 'application/json' },
    body: JSON.stringify({ name, text: value, type: 'secret_text' }),
  });
  if (!r._ok) return { ok: false, error: JSON.stringify(r.errors) };
  return { ok: true, message: `${name} set on ${entry.name}` };
}

async function verifyResource(entry, rawCap) {
  const handler = handlerFor(rawCap);
  if (!handler) return null;
  return await handler.verify(entry);
}

async function teardown(entry) {
  const messages = [];
  const workerDel = await cfFetch(`/workers/scripts/${entry.name}`, { method: 'DELETE' });
  if (workerDel._ok) messages.push(`Worker "${entry.name}" deleted`);
  else if (workerDel._status !== 404) messages.push(`Worker delete failed: ${JSON.stringify(workerDel.errors)}`);

  const needed = resourcesNeeded(entry);
  for (const { handler } of needed) {
    const r = await handler.teardown(entry);
    if (r.message) messages.push(r.message);
  }
  return { ok: true, message: messages.join(' · ') };
}

async function check(entry) {
  return [];
}

return {
  ID, detect, connect, deploy, check, teardown, urlFor,
  setSecret, listSecrets, exists, verifyResource, provision,
};

});

_define("claude-code", function() {
const fs = require('fs');
const path = require('path');
const { resolveAllSkills } = _require("skills");

const ID = 'claude-code';

function detect() {
  return !!(process.env.CLAUDE_CODE || process.env.CLAUDE_CODE_OAUTH_TOKEN || process.env.USER === 'claude');
}

// Map Life lifecycle event names to Claude Code's hook event names
const HOOK_MAP = {
  session_start: 'SessionStart',
  user_prompt: 'UserPromptSubmit',
  pre_tool: 'PreToolUse',
  post_tool: 'PostToolUse',
  stop: 'Stop',
  subagent_stop: 'SubagentStop',
  session_end: 'SessionEnd',
};

async function reconcile(root, index) {
  const generated = [];

  // 1. CLAUDE.md — repo overview
  let md = '# Generated by Life\n\n';
  md += 'This file is generated from `.life` files. Do not edit directly.\n';
  md += 'To change, edit the relevant `.life` file and run `./.life.core reconcile`.\n\n';

  for (const entry of index) {
    if (entry.path === '.') continue;
    md += `## ${entry.name}\n\n`;
    if (entry.summary) md += `${entry.summary}\n\n`;
    if (entry.commands.length) {
      md += 'Commands:\n';
      const cmds = entry._parsed?.commands || {};
      for (const name of entry.commands) {
        const cmd = cmds[name];
        const run = typeof cmd === 'object' ? cmd.run : cmd;
        const approval = (typeof cmd === 'object' && cmd.requires_approval === 'true') ? ' (requires approval)' : '';
        md += `- \`${name}\`: \`${run}\`${approval}\n`;
      }
      md += '\n';
    }
    if (entry._parsed?._body) md += entry._parsed._body + '\n\n';
  }

  fs.writeFileSync(path.join(root, 'CLAUDE.md'), md);
  generated.push('CLAUDE.md');

  // 2. Skills — collect from every .life file, resolve, write to .claude/skills/<name>/SKILL.md
  const allSkillSources = [...new Set(index.flatMap(e => e.skills || []))];
  if (allSkillSources.length) {
    const skillsDir = path.join(root, '.claude', 'skills');
    fs.mkdirSync(skillsDir, { recursive: true });
    const resolved = await resolveAllSkills(allSkillSources, root);
    for (const r of resolved) {
      if (r.error) {
        console.error(`  ⚠ skill ${r.source}: ${r.error}`);
        continue;
      }
      const skillPath = path.join(skillsDir, r.name);
      fs.mkdirSync(skillPath, { recursive: true });
      fs.writeFileSync(path.join(skillPath, 'SKILL.md'), r.content);
      generated.push(`.claude/skills/${r.name}/SKILL.md`);
    }
  }

  // 3. Hooks — collect from every .life file, merge into .claude/settings.json
  const hookEvents = {}; // CC event name → array of hook entries
  for (const entry of index) {
    for (const [lifeEvent, hookDef] of Object.entries(entry.hooks || {})) {
      const ccEvent = HOOK_MAP[lifeEvent];
      if (!ccEvent) {
        const valid = Object.keys(HOOK_MAP).join(', ');
        console.error(`  ⚠ unknown hook event '${lifeEvent}' in ${entry.name}. Valid: ${valid}`);
        continue;
      }
      const run = typeof hookDef === 'object' ? hookDef.run : hookDef;
      const matcher = typeof hookDef === 'object' ? hookDef.matcher : undefined;
      if (!run) continue;

      if (!hookEvents[ccEvent]) hookEvents[ccEvent] = [];
      const entryObj = matcher
        ? { matcher, hooks: [{ type: 'command', command: run }] }
        : { hooks: [{ type: 'command', command: run }] };
      hookEvents[ccEvent].push(entryObj);
    }
  }

  if (Object.keys(hookEvents).length) {
    const settingsPath = path.join(root, '.claude', 'settings.json');
    let settings = {};
    let canWrite = true;
    if (fs.existsSync(settingsPath)) {
      try {
        settings = JSON.parse(fs.readFileSync(settingsPath, 'utf-8'));
        if (settings._generated_by_life !== true) {
          console.error(`  ⚠ .claude/settings.json exists and isn't Life-managed — skipping (would clobber)`);
          canWrite = false;
        }
      } catch {
        console.error(`  ⚠ .claude/settings.json exists but isn't JSON — skipping`);
        canWrite = false;
      }
    }
    if (canWrite) {
      const out = {
        _generated_by_life: true,
        _warning: 'Generated from .life files. Re-run ./.life.core reconcile after changes.',
        hooks: hookEvents,
      };
      fs.mkdirSync(path.dirname(settingsPath), { recursive: true });
      fs.writeFileSync(settingsPath, JSON.stringify(out, null, 2));
      generated.push('.claude/settings.json');
    }
  }

  return generated;
}

return { ID, detect, reconcile };

});

_define("codex", function() {
const fs = require('fs');
const path = require('path');

const ID = 'codex';

function detect() {
  return !!(process.env.CODEX || process.env.OPENAI_API_KEY);
}

function reconcile(root, index) {
  const generated = [];

  let md = '# Generated by Life\n\n';
  md += 'This file is generated from `.life` files. Do not edit directly.\n\n';

  for (const entry of index) {
    if (entry.path === '.') continue;
    md += `## ${entry.name}\n\n`;
    if (entry.summary) md += `${entry.summary}\n\n`;
    if (entry._parsed?._body) md += entry._parsed._body + '\n\n';
  }

  fs.writeFileSync(path.join(root, 'AGENTS.md'), md);
  generated.push('AGENTS.md');
  return generated;
}

return { ID, detect, reconcile };

});


const fs = require('fs');
const path = require('path');
const { execSync } = require('child_process');
const { parseLifeFile, findRoot, buildIndex } = _require("parser");
const { resolveGraph, dependentsOf } = _require("graph");

// Adapters — built into the kernel
const infraAdapters = [_require("cloudflare")];
const harnessAdapters = [_require("claude-code"), _require("codex")];

const ROOT = findRoot(process.cwd());
if (!ROOT) {
  console.error(`Not a Life repo.`);
  console.error(`  Looked for .life.core in ${process.cwd()} and parent directories — not found.`);
  console.error(`  Either cd to the repo root, or install: curl -fsSL https://raw.githubusercontent.com/DomVinyard/life/main/install.sh | sh`);
  process.exit(1);
}

const [,, cmd, ...args] = process.argv;
const commands = { status, explain, check, index: printIndex, run: runCmd, deploy, ping, connect, reconcile, teardown, secret: secretCmd, new: newCmd, deps: depsCmd, help };

if (!cmd || !commands[cmd]) { help(); process.exit(cmd ? 1 : 0); }
Promise.resolve(commands[cmd](...args)).catch(e => { console.error(e.message); process.exit(1); });

// --- Detect environment ---

function detectInfra() {
  return infraAdapters.find(a => a.detect());
}

function detectHarness() {
  return harnessAdapters.find(a => a.detect());
}

// --- Commands ---

function status() {
  const index = buildIndex(ROOT);
  const dirs = index.filter(e => e.path !== '.');
  const { missing, warnings } = resolveGraph(index);
  const infra = detectInfra();
  const harness = detectHarness();

  console.log(`Life repo: ${path.basename(ROOT)}`);
  console.log(`Directories (${dirs.length}): ${dirs.map(d => d.name).join(', ') || '(none)'}`);

  if (infra) {
    console.log(`Infra:     ${infra.ID} (connected)`);
  } else {
    console.log(`Infra:     not connected`);
  }

  if (harness) {
    console.log(`Harness:   ${harness.ID} (detected)`);
  } else {
    console.log(`Harness:   not detected`);
  }

  const otherMissing = missing.filter(m => !m.capability.startsWith('infra.'));
  if (otherMissing.length) {
    console.log(`\nUnresolved capabilities:`);
    otherMissing.forEach(m => console.log(`  ✗ ${m.dir} requires ${m.raw}`));
  }

  // Next step — exactly one suggestion based on current state
  console.log('');
  if (!infra) {
    const opt = infraAdapters[0].ID;
    console.log(`Next: ./.life.core connect ${opt}      # ${infraAdapters.map(a => a.ID).join(' | ')}`);
  } else if (otherMissing.length) {
    console.log(`Next: install a provider for the unresolved capabilities above.`);
  } else if (dirs.length === 0) {
    console.log(`Next: create a directory with a .life file. See ./.life.core help for the format.`);
  } else {
    console.log(`Next: ./.life.core check          # verify everything works`);
    console.log(`      ./.life.core explain <dir>  # learn about a directory`);
  }
}

function explain(target) {
  if (!target) { console.error('Usage: life explain <path>'); process.exit(1); }

  const index = buildIndex(ROOT);
  const { provided } = resolveGraph(index);
  const targetPath = path.resolve(target);

  let best = null;
  for (const entry of index) {
    if (entry.path === '.') continue;
    const ep = path.resolve(ROOT, entry.path);
    if (targetPath.startsWith(ep) && (!best || entry.path.length > best.path.length))
      best = entry;
  }

  if (!best) { console.log(`No .life file governs ${path.relative(ROOT, targetPath)}`); return; }

  const parsed = parseLifeFile(path.join(ROOT, best.file));
  console.log(`${best.name}: ${best.summary}\n`);

  if (best.requires.length) {
    console.log('Requires:');
    best.requires.forEach(r => {
      const cap = r.replace(/:\s*public$/, '');
      const provider = provided.get(cap);
      const infra = detectInfra();
      const resolved = provider ? `✓ (${provider.name})` :
        (cap.startsWith('infra.') && infra) ? `✓ (${infra.ID})` : '✗ not provided';
      console.log(`  ${r} — ${resolved}`);
    });
    console.log();
  }

  if (best.provides.length) console.log('Provides: ' + best.provides.join(', ') + '\n');

  if (best.commands.length) {
    console.log('Commands:');
    const cmds = parsed.commands || {};
    best.commands.forEach(name => {
      const cmd = cmds[name];
      const run = typeof cmd === 'object' ? cmd.run : cmd;
      const flags = [];
      if (typeof cmd === 'object') {
        if (cmd.requires_approval === 'true') flags.push('requires approval');
        if (cmd.public === 'true') flags.push('public');
      }
      console.log(`  ${name}: ${run}${flags.length ? ` [${flags.join(', ')}]` : ''}`);
    });
    console.log();
  }

  if (best.secrets.length) console.log('Secrets: ' + best.secrets.join(', ') + '\n');
  if (parsed._body) console.log(parsed._body);
}

async function check(target) {
  const index = buildIndex(ROOT);
  const { provided, warnings } = resolveGraph(index);
  const infra = detectInfra();
  let failures = 0, passes = 0;
  const providerFailures = new Map();
  const providerSecretLists = new Map(); // entry.name → string[] of secret names set on provider

  async function loadProviderSecrets(entry) {
    if (providerSecretLists.has(entry.name)) return providerSecretLists.get(entry.name);
    const usesSecretStore = entry.requires.some(r => r.replace(/:\s*public$/, '') === 'infra.secret_store');
    if (!usesSecretStore || !infra || !infra.listSecrets) {
      providerSecretLists.set(entry.name, null);
      return null;
    }
    const list = await infra.listSecrets(entry);
    providerSecretLists.set(entry.name, list);
    return list;
  }

  const deployedCache = new Map();
  async function isProviderDeployed(provider) {
    if (deployedCache.has(provider.name)) return deployedCache.get(provider.name);
    // Only directories that themselves require infra.compute could be "deployed" in the provider sense.
    const needsCompute = (provider.requires || []).some(r => r.replace(/:\s*public$/, '') === 'infra.compute');
    if (!needsCompute || !infra || !infra.exists) {
      // Not deployable, so the capability is satisfied by the file alone
      deployedCache.set(provider.name, true);
      return true;
    }
    const live = await infra.exists(provider);
    deployedCache.set(provider.name, live);
    return live;
  }

  async function checkEntry(entry, depth) {
    const indent = '  '.repeat(depth);
    let entryFailures = 0;

    for (const rawCap of entry.requires) {
      const cap = rawCap.replace(/:\s*public$/, '');
      const fromDir = provided.get(cap);
      const fromInfra = cap.startsWith('infra.') && infra;
      if (fromDir) {
        const providerFails = providerFailures.get(fromDir.name) || 0;
        const providerLive = await isProviderDeployed(fromDir);
        if (providerFails > 0) {
          console.log(`${indent}  ✗ ${rawCap} (${fromDir.name} has ${providerFails} failing check${providerFails === 1 ? '' : 's'})`);
          entryFailures++;
        } else if (!providerLive) {
          console.log(`${indent}  ✗ ${rawCap} (${fromDir.name} declares it but is not deployed)`);
          console.log(`${indent}      → ./.life.core deploy ${fromDir.name}`);
          entryFailures++;
        } else {
          console.log(`${indent}  ✓ ${rawCap} (${fromDir.name})`);
          passes++;
        }
      } else if (fromInfra) {
        // Ask the adapter whether the resource actually exists for THIS entry.
        // Returns true/false for resources the adapter handles, null for
        // capabilities with no per-entry resource (e.g. infra.route).
        let resourceLive = null;
        if (infra.verifyResource) {
          resourceLive = await infra.verifyResource(entry, rawCap);
        }
        if (resourceLive === false) {
          console.log(`${indent}  ✗ ${rawCap} (${infra.ID}: not provisioned)`);
          console.log(`${indent}      → ./.life.core deploy ${entry.name}`);
          entryFailures++;
        } else {
          console.log(`${indent}  ✓ ${rawCap} (${infra.ID})`);
          passes++;
        }
      } else {
        console.log(`${indent}  ✗ ${rawCap} — not provided`); entryFailures++;
      }
    }

    // Secrets: query provider when infra.secret_store is required, otherwise process.env
    const providerSecrets = await loadProviderSecrets(entry);
    for (const secret of entry.secrets) {
      let isSet, source;
      if (providerSecrets !== null) {
        isSet = providerSecrets.includes(secret);
        source = ` (${infra.ID})`;
      } else {
        isSet = !!process.env[secret];
        source = ' (env)';
      }
      if (isSet) { console.log(`${indent}  ✓ secret ${secret}${source}`); passes++; }
      else {
        console.log(`${indent}  ✗ secret ${secret} — not set${source}`);
        console.log(`${indent}      → ./.life.core secret set ${entry.name} ${secret} <value>`);
        entryFailures++;
      }
    }

    for (const rawCheck of entry.checks) {
      const checkCmd = typeof rawCheck === 'string' ? rawCheck : rawCheck.run;
      if (!checkCmd) continue;
      try {
        execSync(checkCmd, { cwd: path.join(ROOT, entry.path), stdio: 'pipe', timeout: 30000 });
        console.log(`${indent}  ✓ ${checkCmd}`); passes++;
      } catch { console.log(`${indent}  ✗ ${checkCmd}`); entryFailures++; }
    }

    // Dangerous combo warnings
    const hasPub = entry.requires.some(r => r.includes('public'));
    const hasCommit = entry.requires.includes('storage.commit');
    const hasAuth = entry.requires.some(r => r.startsWith('auth.'));
    const hasAgent = entry.requires.includes('life.agent');
    if (hasPub && hasCommit && !hasAuth)
      console.log(`${indent}  ⚠ public + storage.commit without auth`);
    if (hasAgent)
      console.log(`${indent}  ⚠ life.agent — can spawn sessions and modify code`);

    providerFailures.set(entry.name, entryFailures);
    failures += entryFailures;
  }

  // Toposort: providers first, then dependents
  // Simple approach: do two passes — every directory, in order. The provided map is global,
  // so if check is targeted, we still need to check upstream providers first.
  const allEntries = index.filter(e => e.path !== '.');

  let targetEntries;
  if (target) {
    const targetEntry = allEntries.find(e => e.name === target || e.path === target || e.path.endsWith('/' + target));
    if (!targetEntry) { console.error(`Not found: ${target}`); process.exit(1); }

    // Walk requires transitively, providers-first
    const visited = new Set();
    const ordered = [];
    function walk(e) {
      if (visited.has(e.name)) return;
      visited.add(e.name);
      for (const rawCap of e.requires) {
        const cap = rawCap.replace(/:\s*public$/, '');
        const provider = provided.get(cap);
        if (provider && provider.name !== e.name) walk(provider);
      }
      ordered.push(e);
    }
    walk(targetEntry);
    targetEntries = ordered;
  } else {
    targetEntries = allEntries; // already in some order; capability lookups handle cross-refs
  }

  const focusName = target ? targetEntries[targetEntries.length - 1].name : null;
  for (const entry of targetEntries) {
    const isFocus = entry.name === focusName;
    const isContext = target && !isFocus;
    const tag = isContext ? ' — dep' : '';
    console.log(`\n── ${entry.name} (${entry.path})${tag} ──`);
    await checkEntry(entry, 0);
  }

  console.log(`\n${passes} passed, ${failures} failed`);
  warnings.forEach(w => console.log(`⚠ ${w}`));
  process.exit(failures > 0 ? 1 : 0);
}

function runCmd(nameArg) {
  if (!nameArg) { console.error('Usage: life run <dir.command>'); process.exit(1); }
  const [dirName, cmdName] = nameArg.includes('.') ? nameArg.split('.', 2) : [null, nameArg];
  const index = buildIndex(ROOT);
  const entry = dirName ? index.find(e => e.name === dirName) : index.find(e => e.commands.includes(cmdName));
  if (!entry) { console.error(`Not found: ${nameArg}`); process.exit(1); }

  const parsed = parseLifeFile(path.join(ROOT, entry.file));
  const cmd = parsed.commands?.[cmdName || nameArg];
  if (!cmd) { console.error(`Command ${cmdName} not in ${entry.name}. Have: ${entry.commands.join(', ')}`); process.exit(1); }

  const runTarget = typeof cmd === 'object' ? cmd.run : cmd;
  if (typeof cmd === 'object' && cmd.requires_approval === 'true' && !args.includes('--approve')) {
    console.log(`⚠ ${entry.name}.${cmdName} requires approval. Pass --approve.`);
    process.exit(1);
  }

  try { execSync(runTarget, { cwd: path.join(ROOT, entry.path), stdio: 'inherit' }); }
  catch (e) { process.exit(e.status || 1); }
}

async function deploy(target) {
  if (!target) { console.error('Usage: life deploy <directory>'); process.exit(1); }
  const infra = detectInfra();
  if (!infra) { console.error('No infra provider detected. Set CLOUDFLARE_API_TOKEN.'); process.exit(1); }

  const index = buildIndex(ROOT);
  const entry = index.find(e => e.name === target || e.path === target);
  if (!entry) { console.error(`Not found: ${target}`); process.exit(1); }

  // Pre-flight: check dependency providers for failures
  const { provided } = resolveGraph(index);
  const brokenDeps = [];
  for (const rawCap of entry.requires) {
    const cap = rawCap.replace(/:\s*public$/, '');
    const provider = provided.get(cap);
    if (!provider || provider.name === entry.name) continue;

    let providerFailures = 0;
    // Provider's secrets: query infra if it uses infra.secret_store, else env
    const usesStore = (provider.requires || []).some(r => r.replace(/:\s*public$/, '') === 'infra.secret_store');
    let providerSecrets = null;
    if (usesStore && infra.listSecrets) providerSecrets = await infra.listSecrets(provider);
    for (const s of provider.secrets || []) {
      const isSet = providerSecrets ? providerSecrets.includes(s) : !!process.env[s];
      if (!isSet) providerFailures++;
    }
    // Provider's check commands
    for (const rawCheck of provider.checks || []) {
      const checkCmd = typeof rawCheck === 'string' ? rawCheck : rawCheck.run;
      if (!checkCmd) continue;
      try { execSync(checkCmd, { cwd: path.join(ROOT, provider.path), stdio: 'pipe', timeout: 30000 }); }
      catch { providerFailures++; }
    }
    if (providerFailures > 0) brokenDeps.push({ provider: provider.name, cap: rawCap, failures: providerFailures });
  }

  if (brokenDeps.length && !args.includes('--force')) {
    console.error(`✗ Cannot deploy ${entry.name} — dependencies have failing checks:`);
    brokenDeps.forEach(d => console.error(`  ${d.cap} ← ${d.provider} (${d.failures} failing)`));
    console.error(`\nRun: ./.life.core check ${entry.name}  (to see details)`);
    console.error(`Override:  ./.life.core deploy ${entry.name} --force`);
    process.exit(1);
  }

  console.log(`Deploying ${entry.name} via ${infra.ID}...`);
  const result = await infra.deploy(path.join(ROOT, entry.path), entry);
  if (result.ok) console.log(`✓ ${result.message}`);
  else { console.error(`✗ ${result.error}`); process.exit(1); }
}

async function ping(target) {
  if (!target) { console.error('Usage: life ping <directory>'); process.exit(1); }
  const infra = detectInfra();
  if (!infra) { console.error('No infra provider connected.'); process.exit(1); }
  const index = buildIndex(ROOT);
  const entry = index.find(e => e.name === target || e.path === target);
  if (!entry) { console.error(`Not found: ${target}`); process.exit(1); }

  if (!infra.urlFor) {
    console.error(`Adapter ${infra.ID} does not expose URLs.`);
    process.exit(1);
  }

  // Check existence first — saves us from dumping CF's 404 HTML wall
  if (infra.exists) {
    const stillThere = await infra.exists(entry);
    if (!stillThere) {
      console.log(`✗ ${entry.name} not deployed`);
      console.log(`  → ./.life.core deploy ${entry.name}`);
      process.exit(1);
    }
  }

  const url = await infra.urlFor(entry);
  if (!url) { console.error('Could not determine URL.'); process.exit(1); }

  console.log(`GET ${url}`);
  try {
    const start = Date.now();
    const res = await fetch(url);
    const ms = Date.now() - start;
    const body = await res.text();
    const preview = body.length > 200 ? body.slice(0, 200) + '…' : body;
    console.log(`${res.status} ${res.statusText} · ${ms}ms`);
    if (preview.trim()) console.log(preview);
    process.exit(res.ok ? 0 : 1);
  } catch (e) {
    console.error(`✗ ${e.message}`);
    process.exit(1);
  }
}

async function connect(name) {
  if (!name) { console.error('Usage: life connect <provider>'); process.exit(1); }
  const adapter = infraAdapters.find(a => a.ID === name);
  if (!adapter) {
    console.error(`Unknown provider: ${name}. Available: ${infraAdapters.map(a => a.ID).join(', ')}`);
    process.exit(1);
  }

  const result = await adapter.connect();
  if (result.ok) console.log(`✓ Connected to ${name}${result.account ? ': ' + result.account : ''}`);
  else { console.error(`✗ ${result.error}`); process.exit(1); }
}

async function reconcile() {
  const index = buildIndex(ROOT);
  const harness = detectHarness();
  const targets = harness ? [harness] : harnessAdapters;
  for (const h of targets) {
    const files = await h.reconcile(ROOT, index);
    files.forEach(f => console.log(`Generated: ${f}`));
  }
}

async function secretCmd(action, target, secretName, ...rest) {
  if (action !== 'set') {
    console.error('Usage: life secret set <directory> <NAME> <value>');
    process.exit(1);
  }
  if (!target || !secretName || rest.length === 0) {
    console.error('Usage: life secret set <directory> <NAME> <value>');
    process.exit(1);
  }
  const value = rest.join(' ');
  const infra = detectInfra();
  if (!infra) { console.error('No infra provider connected.'); process.exit(1); }
  if (!infra.setSecret) {
    console.error(`Adapter ${infra.ID} does not support setting secrets.`);
    process.exit(1);
  }

  const index = buildIndex(ROOT);
  const entry = index.find(e => e.name === target || e.path === target);
  if (!entry) { console.error(`Not found: ${target}`); process.exit(1); }

  const result = await infra.setSecret(entry, secretName, value);
  if (result.ok) console.log(`✓ ${result.message}`);
  else { console.error(`✗ ${result.error}`); process.exit(1); }
}

function newCmd(name) {
  if (!name) {
    console.error('Usage: life new <directory>');
    process.exit(1);
  }
  if (!/^[a-z][a-z0-9_-]*$/.test(name)) {
    console.error(`Invalid name: ${name}. Use lowercase letters, digits, _ and -.`);
    process.exit(1);
  }
  const dir = path.join(ROOT, name);
  if (fs.existsSync(dir)) {
    console.error(`Already exists: ${name}/`);
    process.exit(1);
  }

  fs.mkdirSync(path.join(dir, 'src'), { recursive: true });

  const lifeFile = `life: 0.1
name: ${name}
summary: TODO — one-line description of what this directory does

requires:
  - infra.compute
  - infra.route

provides: []
secrets: []

commands:
  test:
    run: echo "${name} test passed"

checks:
  - echo "${name} check passed"

---

# ${name}

TODO — describe how this directory works for agents.
`;

  const workerFile = `// TODO — implement
export default {
  async fetch(request) {
    return new Response('not implemented', { status: 501 });
  },
};
`;

  fs.writeFileSync(path.join(dir, '.life'), lifeFile);
  fs.writeFileSync(path.join(dir, 'src', 'worker.js'), workerFile);

  console.log(`Created ${name}/`);
  console.log(`  ${name}/.life`);
  console.log(`  ${name}/src/worker.js`);
  console.log('');
  console.log(`Next: ./.life.core check ${name}     # verify it parses + resolves`);
  console.log(`      ./.life.core deploy ${name}    # deploy when ready`);
}

async function teardown(target) {
  if (!target) { console.error('Usage: life teardown <directory> --confirm'); process.exit(1); }
  const infra = detectInfra();
  if (!infra) { console.error('No infra provider.'); process.exit(1); }

  const index = buildIndex(ROOT);
  const entry = index.find(e => e.name === target);
  if (!entry) { console.error(`Not found: ${target}`); process.exit(1); }

  // Find directories that require any capability THIS directory provides
  const dirs = index.filter(e => e.path !== '.');
  const consumers = (entry.provides || []).flatMap(cap =>
    dirs
      .filter(d => d.name !== entry.name && (d.requires || []).some(r => r.replace(/:\s*public$/, '') === cap))
      .map(d => ({ dir: d.name, cap }))
  );

  // Of those consumers, which are currently deployed (i.e. would be broken by teardown)
  let liveConsumers = consumers;
  if (infra.exists && consumers.length) {
    const checks = await Promise.all(consumers.map(async c => ({
      ...c,
      live: await infra.exists(dirs.find(d => d.name === c.dir)),
    })));
    liveConsumers = checks.filter(c => c.live);
  }

  if (liveConsumers.length && !args.includes('--force')) {
    console.error(`✗ Cannot teardown ${target} — live consumers would break:`);
    liveConsumers.forEach(c => console.error(`  ${c.dir} requires ${c.cap}`));
    console.error(`\nTeardown consumers first, or override:  ./.life.core teardown ${target} --force`);
    process.exit(1);
  }

  // --force implies --confirm. Skip the prompt when forcing.
  if (!args.includes('--confirm') && !args.includes('--force')) {
    console.log(`⚠ ./.life.core teardown ${target} is destructive. Pass --confirm to proceed.`);
    if (consumers.length) {
      console.log(`\nDirectories that declare a dependency on ${target}:`);
      consumers.forEach(c => console.log(`  ${c.dir} (${c.cap})`));
    }
    process.exit(1);
  }

  const result = await infra.teardown(entry);
  if (result.ok) console.log(`✓ ${result.message}`);
  else { console.error(`✗ ${result.error}`); process.exit(1); }
}

function depsCmd(target) {
  const index = buildIndex(ROOT);
  const { provided } = resolveGraph(index);
  const dirs = index.filter(e => e.path !== '.');

  // Helper: format `← capability (source)` consistently
  function reqLine(rawCap) {
    const cap = rawCap.replace(/:\s*public$/, '');
    const provider = provided.get(cap);
    if (provider) return `← ${rawCap} (${provider.name})`;
    if (cap.startsWith('infra.') || cap.startsWith('storage.') || cap.startsWith('model.') || cap.startsWith('life.'))
      return `← ${rawCap} (infra)`;
    return `← ${rawCap} (NOT PROVIDED)`;
  }

  // Helper: format `→ capability (consumers or "unused")`
  function provLine(p) {
    const consumers = dirs.filter(d =>
      (d.requires || []).some(r => r.replace(/:\s*public$/, '') === p)
    );
    const tag = consumers.length ? consumers.map(c => c.name).join(', ') : 'unused';
    return `→ ${p} (${tag})`;
  }

  if (!target) {
    console.log('Capability graph:');
    for (const entry of dirs) {
      const requires = entry.requires || [];
      const provides = entry.provides || [];
      if (!requires.length && !provides.length) continue;
      console.log(`\n  ${entry.name}`);
      requires.forEach(r => console.log(`    ${reqLine(r)}`));
      provides.forEach(p => console.log(`    ${provLine(p)}`));
    }
    return;
  }

  const entry = dirs.find(e => e.name === target || e.path === target);
  if (!entry) { console.error(`Not found: ${target}`); process.exit(1); }

  console.log(`${entry.name}:\n`);

  if (entry.requires.length) {
    console.log('Requires (depends on):');
    entry.requires.forEach(r => console.log(`  ${reqLine(r)}`));
    console.log();
  }

  if (entry.provides.length) {
    console.log('Provides (consumed by):');
    entry.provides.forEach(p => console.log(`  ${provLine(p)}`));
  }
}

function printIndex() {
  console.log(JSON.stringify(buildIndex(ROOT).map(({ _parsed, ...e }) => e), null, 2));
}

function help() {
  console.log(`Life 0.1 — repo convention for agent-legible infra

Orient
  status              What's here, what's connected, what's missing
  explain <path>      What governs this path
  deps [dir]          Show requires/provides graph (both directions)
  index               Full JSON index of all .life files

Author
  new <dir>           Scaffold a new directory with .life + worker.js
  check [dir]         Verify capabilities, secrets, run checks
  run <dir.cmd>       Execute a command from a .life file
  reconcile           Regenerate harness files (CLAUDE.md, AGENTS.md)

Infra
  connect <provider>                Connect an infra provider (e.g. cloudflare)
  deploy <dir>                      Deploy a directory's infra (prints URL)
  ping <dir>                        Hit the deployed URL and report status
  secret set <dir> <NAME> <value>   Set a secret on a deployed directory
  teardown <dir> --confirm          Destroy a directory's infra

.life schema (top-level fields):
  name, summary, requires[], provides[], commands{}, checks[],
  secrets[], skills[], hooks{}

  skills:  - ./local/path           (reads SKILL.md)
           - github.com/u/r/p@sha   (fetches raw SKILL.md, caches)
  hooks:   session_start | user_prompt | pre_tool | post_tool |
           stop | subagent_stop | session_end
           each is { run: "...", matcher?: "Bash" } or a plain command

If you just installed: run \`status\` first.`);
}

})();
