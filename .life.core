#!/usr/bin/env node
// Life 0.1 kernel — single-file distribution
// Built: 2026-05-28T13:51:03.659Z

(function() {
const _modules = {};
function _define(name, factory) { let m; _modules[name] = () => m || (m = factory()); }
function _require(name) { if (_modules[name]) return _modules[name](); return require(name); }

_define("parser", function() {
const fs = require('fs');
const path = require('path');

function parseLifeFile(filePath) {
  const raw = fs.readFileSync(filePath, 'utf-8');
  const match = raw.match(/^([\s\S]*?)---\s*\n([\s\S]*)$/);
  const frontmatter = match ? match[1] : raw;
  const body = match ? match[2].trim() : '';
  const parsed = parseYaml(frontmatter.trim());
  return { ...parsed, _body: body, _path: filePath };
}

function parseYaml(text) {
  const result = {};
  let currentKey = null;
  let currentSubKey = null;

  for (const line of text.split('\n')) {
    if (line.trim() === '' || line.trim().startsWith('#')) continue;
    const indent = line.match(/^(\s*)/)[1].length;

    if (indent === 0) {
      const m = line.match(/^(\w[\w_-]*):\s*(.*)/);
      if (m) {
        currentKey = m[1];
        currentSubKey = null;
        result[currentKey] = m[2].trim() || undefined;
      }
      continue;
    }

    const listMatch = line.match(/^\s+-\s+(.*)/);
    if (listMatch && currentKey) {
      if (!Array.isArray(result[currentKey])) result[currentKey] = [];
      result[currentKey].push(listMatch[1].trim());
      continue;
    }

    if (indent === 2 && currentKey) {
      const m = line.match(/^\s{2}(\w[\w_-]*):\s*(.*)/);
      if (m) {
        if (typeof result[currentKey] !== 'object' || Array.isArray(result[currentKey]))
          result[currentKey] = {};
        currentSubKey = m[1];
        result[currentKey][currentSubKey] = m[2].trim() || {};
      }
      continue;
    }

    if (indent >= 4 && currentKey && currentSubKey) {
      const m = line.trim().match(/^(\w[\w_-]*):\s*(.*)/);
      if (m && typeof result[currentKey][currentSubKey] === 'object') {
        let val = m[2].trim();
        if (val.startsWith('[') && val.endsWith(']'))
          val = val.slice(1, -1).split(',').map(s => s.trim()).filter(Boolean);
        result[currentKey][currentSubKey][m[1]] = val;
      }
      continue;
    }
  }
  return result;
}

function findRoot(dir) {
  let d = path.resolve(dir);
  while (d !== path.dirname(d)) {
    if (fs.existsSync(path.join(d, '.life.core'))) return d;
    d = path.dirname(d);
  }
  return null;
}

function discoverLifeFiles(root) {
  const files = [];
  // Root .life file
  const rootLife = path.join(root, '.life');
  if (fs.existsSync(rootLife) && fs.statSync(rootLife).isFile()) files.push(rootLife);

  function walk(dir, depth) {
    if (depth > 5) return;
    const base = path.basename(dir);
    if (['node_modules', '.git', 'dist'].includes(base)) return;

    if (dir !== root) {
      const lf = path.join(dir, '.life');
      if (fs.existsSync(lf) && fs.statSync(lf).isFile()) files.push(lf);
    }

    try {
      for (const entry of fs.readdirSync(dir)) {
        if (entry.startsWith('.') && entry !== '.life') continue;
        const full = path.join(dir, entry);
        if (fs.statSync(full).isDirectory()) walk(full, depth + 1);
      }
    } catch {}
  }
  walk(root, 0);
  return files;
}

function buildIndex(root) {
  return discoverLifeFiles(root).map(f => {
    try {
      const parsed = parseLifeFile(f);
      const relPath = path.relative(root, path.dirname(f));
      return {
        path: relPath || '.',
        file: path.relative(root, f),
        name: parsed.name || path.basename(relPath || '.'),
        summary: parsed.summary || '',
        requires: parsed.requires || [],
        provides: parsed.provides || [],
        commands: parsed.commands ? Object.keys(parsed.commands) : [],
        checks: parsed.checks || [],
        secrets: parsed.secrets || [],
        _parsed: parsed,
      };
    } catch (e) {
      console.error(`Warning: ${f}: ${e.message}`);
      return null;
    }
  }).filter(Boolean);
}

return { parseLifeFile, findRoot, discoverLifeFiles, buildIndex };

});

_define("graph", function() {
function resolveGraph(index) {
  const provided = new Map();
  const missing = [];
  const warnings = [];

  for (const entry of index) {
    for (const cap of entry.provides || []) {
      if (provided.has(cap))
        warnings.push(`Ambiguous: ${cap} from ${provided.get(cap).name} and ${entry.name}`);
      provided.set(cap, entry);
    }
  }

  for (const entry of index) {
    for (const rawCap of entry.requires || []) {
      const cap = rawCap.replace(/:\s*public$/, '');
      if (!provided.has(cap))
        missing.push({ dir: entry.name, capability: cap, raw: rawCap });
    }
  }

  return { provided, missing, warnings };
}

function dependentsOf(name, index) {
  return index.filter(e =>
    (e.requires || []).some(r => r.replace(/:\s*public$/, '').startsWith(name + '.'))
  );
}

return { resolveGraph, dependentsOf };

});

_define("cloudflare", function() {
const fs = require('fs');
const path = require('path');

const ID = 'cloudflare';

function detect() {
  return !!(process.env.CLOUDFLARE_API_TOKEN && process.env.CLOUDFLARE_ACCOUNT_ID);
}

function headers() {
  return { 'Authorization': `Bearer ${process.env.CLOUDFLARE_API_TOKEN}` };
}

function accountUrl(p) {
  return `https://api.cloudflare.com/client/v4/accounts/${process.env.CLOUDFLARE_ACCOUNT_ID}${p || ''}`;
}

async function connect() {
  const token = process.env.CLOUDFLARE_API_TOKEN;
  const accountId = process.env.CLOUDFLARE_ACCOUNT_ID;

  if (!token) return { ok: false, error: 'CLOUDFLARE_API_TOKEN not set' };
  if (!accountId) return { ok: false, error: 'CLOUDFLARE_ACCOUNT_ID not set' };

  // cfat_ tokens fail /user/tokens/verify — use account endpoint instead
  try {
    const res = await fetch(accountUrl(), { headers: headers() });
    const data = await res.json();
    if (!data.success)
      return { ok: false, error: data.errors?.[0]?.message || 'Account not accessible' };
    return { ok: true, account: data.result.name };
  } catch (e) {
    return { ok: false, error: e.message };
  }
}

async function deploy(dir, entry) {
  const workerPath = path.join(dir, 'src', 'worker.js');
  if (!fs.existsSync(workerPath))
    return { ok: false, error: `No src/worker.js in ${dir}` };

  const code = fs.readFileSync(workerPath, 'utf-8');
  const name = entry.name;

  const formData = new FormData();
  formData.append('metadata', new Blob([JSON.stringify({
    main_module: 'worker.js',
    compatibility_date: '2024-01-01',
  })], { type: 'application/json' }));
  formData.append('worker.js', new Blob([code], { type: 'application/javascript+module' }), 'worker.js');

  try {
    const res = await fetch(accountUrl(`/workers/scripts/${name}`), {
      method: 'PUT',
      headers: headers(),
      body: formData,
    });
    const data = await res.json();
    if (!data.success)
      return { ok: false, error: JSON.stringify(data.errors) };

    // Enable the workers.dev subdomain so the worker is actually reachable
    let url = null;
    try {
      await fetch(accountUrl(`/workers/scripts/${name}/subdomain`), {
        method: 'POST',
        headers: { ...headers(), 'Content-Type': 'application/json' },
        body: JSON.stringify({ enabled: true }),
      });
      // Fetch account subdomain to construct URL
      const subRes = await fetch(accountUrl('/workers/subdomain'), { headers: headers() });
      const subData = await subRes.json();
      if (subData.success && subData.result?.subdomain) {
        url = `https://${name}.${subData.result.subdomain}.workers.dev`;
      }
    } catch {}

    return {
      ok: true,
      message: url
        ? `Worker "${name}" deployed → ${url}`
        : `Worker "${name}" deployed`,
      url,
    };
  } catch (e) {
    return { ok: false, error: e.message };
  }
}

async function urlFor(entry) {
  try {
    const subRes = await fetch(accountUrl('/workers/subdomain'), { headers: headers() });
    const subData = await subRes.json();
    if (subData.success && subData.result?.subdomain) {
      return `https://${entry.name}.${subData.result.subdomain}.workers.dev`;
    }
  } catch {}
  return null;
}

async function setSecret(entry, name, value) {
  try {
    // /settings returns JSON; /workers/scripts/{n} returns multipart script bytes
    const checkRes = await fetch(accountUrl(`/workers/scripts/${entry.name}/settings`), { headers: headers() });
    if (checkRes.status === 404) {
      return { ok: false, error: `Deploy ${entry.name} first, then set secrets.` };
    }
    const res = await fetch(accountUrl(`/workers/scripts/${entry.name}/secrets`), {
      method: 'PUT',
      headers: { ...headers(), 'Content-Type': 'application/json' },
      body: JSON.stringify({ name, text: value, type: 'secret_text' }),
    });
    const data = await res.json();
    if (!data.success) return { ok: false, error: JSON.stringify(data.errors) };
    return { ok: true, message: `${name} set on ${entry.name}` };
  } catch (e) {
    return { ok: false, error: e.message };
  }
}

async function listSecrets(entry) {
  // Returns array of secret names bound to the deployed worker, or null if worker doesn't exist
  try {
    const res = await fetch(accountUrl(`/workers/scripts/${entry.name}/secrets`), { headers: headers() });
    if (res.status === 404) return null;
    const data = await res.json();
    if (!data.success) return null;
    return (data.result || []).map(s => s.name);
  } catch {
    return null;
  }
}

async function check(entry) {
  const results = [];

  // Check if Worker exists
  if ((entry.requires || []).some(r => r.includes('infra.compute'))) {
    try {
      const res = await fetch(accountUrl(`/workers/scripts/${entry.name}`), { headers: headers() });
      const data = await res.json();
      results.push({
        check: `Worker "${entry.name}"`,
        ok: data.success,
        detail: data.success ? 'exists' : 'not deployed',
      });
    } catch (e) {
      results.push({ check: `Worker "${entry.name}"`, ok: false, detail: e.message });
    }
  }

  // Check secrets
  for (const secret of entry.secrets || []) {
    results.push({
      check: `secret ${secret}`,
      ok: !!process.env[secret],
      detail: process.env[secret] ? 'set in env' : 'not set',
    });
  }

  return results;
}

async function teardown(entry) {
  try {
    const res = await fetch(accountUrl(`/workers/scripts/${entry.name}`), {
      method: 'DELETE',
      headers: headers(),
    });
    const data = await res.json();
    return { ok: data.success, message: data.success ? `Worker "${entry.name}" deleted` : 'Failed' };
  } catch (e) {
    return { ok: false, error: e.message };
  }
}

return { ID, detect, connect, deploy, check, teardown, urlFor, setSecret, listSecrets };

});

_define("claude-code", function() {
const fs = require('fs');
const path = require('path');

const ID = 'claude-code';

function detect() {
  return !!(process.env.CLAUDE_CODE || process.env.CLAUDE_CODE_OAUTH_TOKEN || process.env.USER === 'claude');
}

function reconcile(root, index) {
  const generated = [];

  // Generate CLAUDE.md from all .life files
  let md = '# Generated by Life\n\n';
  md += 'This file is generated from `.life` files. Do not edit directly.\n';
  md += 'To change, edit the relevant `.life` file and run `life reconcile`.\n\n';

  for (const entry of index) {
    if (entry.path === '.') continue;
    md += `## ${entry.name}\n\n`;
    if (entry.summary) md += `${entry.summary}\n\n`;
    if (entry.commands.length) {
      md += 'Commands:\n';
      const cmds = entry._parsed?.commands || {};
      for (const name of entry.commands) {
        const cmd = cmds[name];
        const run = typeof cmd === 'object' ? cmd.run : cmd;
        const approval = (typeof cmd === 'object' && cmd.requires_approval === 'true') ? ' (requires approval)' : '';
        md += `- \`${name}\`: \`${run}\`${approval}\n`;
      }
      md += '\n';
    }
    if (entry._parsed?._body) {
      md += entry._parsed._body + '\n\n';
    }
  }

  const claudeMdPath = path.join(root, 'CLAUDE.md');
  fs.writeFileSync(claudeMdPath, md);
  generated.push('CLAUDE.md');

  return generated;
}

return { ID, detect, reconcile };

});

