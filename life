    const otherMissing = missing.filter(m => !m.capability.startsWith('infra.'));
    if (infraMissing.length && !infra)
      console.log(`\n${infraMissing.length} infra capabilities unresolved — connect a provider`);
    if (otherMissing.length) {
      console.log(`\nUnresolved:`);
      otherMissing.forEach(m => console.log(`  ✗ ${m.dir} requires ${m.raw}`));
    }
  }
  if (missing.length === 0) console.log(`\nAll capabilities resolved.`);
