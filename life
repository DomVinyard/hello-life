async function connect() {
  const token = process.env.CLOUDFLARE_API_TOKEN;
  const accountId = process.env.CLOUDFLARE_ACCOUNT_ID;

  if (!token) return { ok: false, error: 'CLOUDFLARE_API_TOKEN not set' };
  if (!accountId) return { ok: false, error: 'CLOUDFLARE_ACCOUNT_ID not set' };

  // cfat_ tokens fail /user/tokens/verify — use account endpoint instead
  try {
    const res = await fetch(accountUrl(), { headers: headers() });
    const data = await res.json();
    if (!data.success)
      return { ok: false, error: data.errors?.[0]?.message || 'Account not accessible' };
    return { ok: true, account: data.result.name };
  } catch (e) {
    return { ok: false, error: e.message };
  }
