  const { missing, warnings } = resolveGraph(index);
  const infra = detectInfra();
  const harness = detectHarness();

  console.log(`Life repo: ${path.basename(ROOT)}`);
  console.log(`Directories: ${index.filter(e => e.path !== '.').length}`);
  console.log(`Infra: ${infra ? infra.ID + ' (detected)' : 'none (set CLOUDFLARE_API_TOKEN)'}`);
  console.log(`Harness: ${harness ? harness.ID + ' (detected)' : 'none'}`);

